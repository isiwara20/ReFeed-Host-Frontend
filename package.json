{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "test:frontend": "npx cypress open",
    "test:frontend:headless": "npx cypress run",
    "test:ngo": "npx cypress run --spec 'cypress/e2e/ngo_userReg/*.cy.js'",
    "test:ngo:registration": "npx cypress run --spec 'cypress/e2e/ngo_userReg/registration.cy.js'",
    "test:ngo:password": "npx cypress run --spec 'cypress/e2e/ngo_userReg/passwordReset.cy.js'",
    "test:ngo:food": "npx cypress run --spec 'cypress/e2e/ngo_userReg/foodRequest.cy.js'",
    "test:ngo:address": "npx cypress run --spec 'cypress/e2e/ngo_userReg/addressManagement.cy.js'",
    "test:ngo:dashboard": "npx cypress run --spec 'cypress/e2e/ngo_userReg/ngoDashboard.cy.js'",
    "test:ngo:payment": "npx cypress run --spec 'cypress/e2e/ngo_userReg/donationPayment.cy.js'",
    "test:ngo:workflow": "npx cypress run --spec 'cypress/e2e/ngo_userReg/completeWorkflow.cy.js'",
    "test:ngo:performance": "npx cypress run --spec 'cypress/e2e/ngo_userReg/performance.cy.js'",
    "test:cypress:admin": "cypress run --e2e --spec \"cypress/e2e/administration/**/*\"",
    "test:cypress:donor": "cypress run --e2e --spec \"cypress/e2e/donor/**/*\"",
    "test:cypress:ngo": "cypress run --e2e --spec \"cypress/e2e/ngo/**/*\"",
    "test:cypress:messages": "cypress run --e2e --spec \"cypress/e2e/**/messages/**/*\"",
    "test:cypress:notifications": "cypress run --e2e --spec \"cypress/e2e/**/notifications/**/*\"",
    "test:cypress:smoke": "cypress run --e2e --spec \"cypress/e2e/messages/**/*,cypress/e2e/notifications/**/*\"",
    "test:cypress:all-workflows": "cypress run --e2e --spec \"cypress/e2e/administration/**/*,cypress/e2e/donor/**/*,cypress/e2e/ngo/**/*\"",
    "cypress:run": "npx cypress run"

  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "cypress": "^15.13.0"
  }
}
